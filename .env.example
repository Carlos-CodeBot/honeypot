SECRET_KEY=super-secreto

SITE_TITLE=NovaCore Cloud
SITE_SUBTITLE=Infraestructura digital para empresas en crecimiento
HERO_TAGLINE=Plataforma integral de facturación, CRM y analítica
THEME_COLOR=#376a12

ADMIN_USER=analista
ADMIN_PASS=cambia-esta-clave

SIEM_HINT=crowdsec

TRAINING_FILE=/data/training_samples.txt
MODEL_PATH=/data/adaptive_model.joblib
MAX_UPLOAD_SIZE=10485760
FILTER_SCRIPT=/app/filtro/ossec_filter.py
CUSTOM_FRONT_DIR=/data/custom_front

SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax

# ============================================================
# MODOS DE EJECUCION
# ============================================================
#
# Modo honeypot publico tradicional:
#   ENABLE_PUBLIC_SITE=1
#   ENABLE_DASHBOARD=0
#   ENABLE_LOG_AGENT=0
#
# Modo dashboard central:
#   ENABLE_PUBLIC_SITE=0
#   ENABLE_DASHBOARD=1
#   ENABLE_LOG_AGENT=0
#
# Modo agente lector de logs:
#   ENABLE_PUBLIC_SITE=0
#   ENABLE_DASHBOARD=0
#   ENABLE_LOG_AGENT=1
#
ENABLE_PUBLIC_SITE=1
ENABLE_DASHBOARD=1
ENABLE_LOG_AGENT=0

# ============================================================
# REENVIO DE EVENTOS A DASHBOARD REMOTO
# ============================================================
#
# En agentes, usar:
#   FORWARD_LOG_URL=http://IP_DEL_DASHBOARD/api/ingest-event
#
# Si el dashboard expone Flask directamente:
#   FORWARD_LOG_URL=http://IP_DEL_DASHBOARD:8000/api/ingest-event
#
FORWARD_LOG_URL=
FORWARD_LOG_TOKEN=

# ============================================================
# INGESTA REMOTA EN DASHBOARD
# ============================================================
#
# En dashboard:
#   INGEST_TOKEN debe coincidir con FORWARD_LOG_TOKEN del agente.
#   INGEST_HMAC_SECRET debe coincidir en dashboard y agentes.
#
INGEST_TOKEN=
INGEST_HMAC_SECRET=
INGEST_MAX_SKEW_SECONDS=120

# ============================================================
# AGENTE LECTOR DE LOGS
# ============================================================
#
# Usado solo cuando ENABLE_LOG_AGENT=1.
# Este modo no levanta sitio falso ni dashboard.
# Lee access logs del servidor real y envia eventos al dashboard.
#
# En Docker se recomienda montar el log real como /logs/access.log:
#
# Nginx:
#   /var/log/nginx/access.log:/logs/access.log:ro
#
# Apache Debian/Ubuntu:
#   /var/log/apache2/access.log:/logs/access.log:ro
#
# Apache CentOS/RHEL:
#   /var/log/httpd/access_log:/logs/access.log:ro
#
LOG_AGENT_PATH=/logs/access.log
LOG_AGENT_STATE_FILE=/data/log_agent.state
LOG_AGENT_POLL_INTERVAL=2

# Si es 1, solo envia eventos detectados como ataque.
# Si es 0, envia todo el access log al dashboard.
LOG_AGENT_SEND_ONLY_ATTACKS=0